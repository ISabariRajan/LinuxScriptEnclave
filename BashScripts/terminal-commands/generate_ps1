#! /bin/bash

source ~/.bashrc
D_APPOS="\""
VARIABLE_COLOR="\${LIGHT_BLUE}"
VALUE_COLOR="\${LIGHT_WHITE}"


if [ "$USER" = "root" ]; then
    USER_IDENTIFIER_BLOCK="\${DARK_RED}"
    BLINKER_IDENTIFIER_BLOCK="\${BLINKER_DARK_RED}"
else
    USER_IDENTIFIER_BLOCK="\${LIGHT_GREEN}"
    BLINKER_IDENTIFIER_BLOCK="\${LIGHT_GREEN}"
fi
COMMAND_POINTER=$BLINKER_IDENTIFIER_BLOCK" #> \${NO_BLINKER}"
DIR_PATH_AND_BRANCH=$VALUE_COLOR"\\\$(dircom get_dir) $VARIABLE_COLOR(\\\$(gitcom parse_git_branch))$VALUE_COLOR"
USER_MOD=$VALUE_COLOR$USER_IDENTIFIER_BLOCK$USER"\${DARK_WHITE}@"
HOST_AND_IP=$VALUE_COLOR"\\\$(terminal get_host_ip) $VARIABLE_COLOR(\\\$(hostname))$VALUE_COLOR"

LINE1=$VARIABLE_COLOR"Directory $VALUE_COLOR(Branch)$VARIABLE_COLOR #> "$DIR_PATH_AND_BRANCH"\n"
LINE2=$VARIABLE_COLOR"User@IP $VALUE_COLOR(Hostname)$VARIABLE_COLOR #> "$USER_MOD$HOST_AND_IP"\n"
LINE3=$VARIABLE_COLOR"Command           "$USER_IDENTIFIER_BLOCK$COMMAND_POINTER

CHECK="PS1=$D_APPOS"
if grep -Fq "$CHECK" $BASHRC
then
    echo "FOUND"
    sed -i "/$CHECK/c\\" $BASHRC
fi

echo "PS1=$D_APPOS$LINE1$LINE2$LINE3$D_APPOS" >> $BASHRC

source ~/.bashrc
